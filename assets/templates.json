  "shot1": "<!DOCTYPE html>\n<html><head><meta charset=\"UTF-8\"><style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { background: #000; display: flex; justify-content: center; font-family: -apple-system, 'PingFang SC', sans-serif; }\n.c { width: 1080px; height: 1920px; background: linear-gradient(135deg, #0a0a1a, #1a1a2e); position: relative; overflow: hidden; }\n.grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(0,212,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(0,212,255,0.02) 1px, transparent 1px); background-size: 50px 50px; }\n.content { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; width: 90%; }\n.title { font-size: 60px; font-weight: 900; color: #fff; line-height: 1.4; opacity: 0; animation: fadeInUp 0.8s ease-out 0.2s forwards; }\n.hl { color: #00d4ff; }\n.num { font-size: 180px; font-weight: 900; color: #00d4ff; margin: 40px 0; line-height: 1; opacity: 0; animation: scaleIn 1s cubic-bezier(0.34, 1.56, 0.64, 1) 0.8s forwards; }\n.unit { font-size: 60px; color: #ff3366; }\n.sub { font-size: 44px; font-weight: 700; color: #ff8c00; padding: 15px 35px; background: rgba(255,140,0,0.15); border: 2px solid rgba(255,140,0,0.5); border-radius: 10px; display: inline-block; opacity: 0; animation: fadeInUp 0.6s ease-out 1.8s forwards; }\n@keyframes fadeInUp { 0% { opacity: 0; transform: translateY(30px); } 100% { opacity: 1; transform: translateY(0); } }\n@keyframes scaleIn { 0% { opacity: 0; transform: scale(0.2); } 60% { transform: scale(1.05); } 100% { opacity: 1; transform: scale(1); } }\n.line { position: absolute; top: 32%; left: 0; height: 3px; background: linear-gradient(90deg, transparent, #00d4ff, transparent); animation: expandLine 0.8s ease-out 1.2s forwards; }\n@keyframes expandLine { 0% { width: 0; opacity: 0; } 100% { width: 100%; opacity: 1; } }\n.bar { position: absolute; bottom: 80px; left: 10%; width: 80%; height: 2px; background: linear-gradient(90deg, #00d4ff, #ff3366, #ff8c00); }\n.logo { position: absolute; bottom: 110px; right: 60px; font-size: 22px; color: rgba(255,255,255,0.35); }\n</style></head><body>\n<div class=\"c\"><div class=\"grid\"></div><div class=\"line\"></div>\n<div class=\"content\">\n<div class=\"title\">{{TITLE}}</div>\n<div class=\"num\">{{NUMBER}}<span class=\"unit\">{{UNIT}}</span></div>\n<div class=\"sub\">{{SUBTITLE}}</div>\n</div><div class=\"bar\"></div><div class=\"logo\">AI科技观察</div></div>\n</body></html>",

  "shot2": "<!DOCTYPE html>\n<html><head><meta charset=\"UTF-8\"><style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { background: #000; display: flex; justify-content: center; font-family: -apple-system, 'PingFang SC', sans-serif; }\n.c { width: 1080px; height: 1920px; background: linear-gradient(180deg, #0f0f1f, #1a1a2e); position: relative; }\n.hd { position: absolute; top: 100px; left: 50%; transform: translateX(-50%); font-size: 44px; font-weight: 800; color: #fff; padding: 15px 30px; background: rgba(0,212,255,0.1); border: 2px solid rgba(0,212,255,0.4); border-radius: 8px; opacity: 0; animation: fadeIn 0.5s ease-out 0.2s forwards; }\n.cards { position: absolute; top: 220px; left: 50px; right: 50px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }\n.card { background: rgba(26,26,46,0.9); border: 1px solid rgba(0,212,255,0.2); border-radius: 12px; padding: 28px 24px; text-align: center; opacity: 0; }\n.card:nth-child(1) { animation: scaleIn 0.5s ease-out 0.4s forwards; }\n.card:nth-child(2) { animation: scaleIn 0.5s ease-out 0.6s forwards; }\n.card:nth-child(3) { animation: scaleIn 0.5s ease-out 0.8s forwards; }\n.card:nth-child(4) { animation: scaleIn 0.5s ease-out 1.0s forwards; }\n.ic { width: 70px; height: 70px; margin: 0 auto 15px; background: linear-gradient(135deg, #00d4ff, #0099cc); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 32px; }\n.lb { font-size: 20px; color: rgba(255,255,255,0.5); margin-bottom: 8px; }\n.vl { font-size: 36px; font-weight: 900; color: #00d4ff; }\n.vl.r { color: #ff3366; }\n.vl.o { color: #ff8c00; }\n.desc { font-size: 16px; color: rgba(255,255,255,0.4); margin-top: 8px; }\n@keyframes fadeIn { 0% { opacity: 0; } 100% { opacity: 1; } }\n@keyframes scaleIn { 0% { opacity: 0; transform: scale(0.85); } 100% { opacity: 1; transform: scale(1); } }\n.sum { position: absolute; bottom: 150px; left: 50px; right: 50px; padding: 26px; background: rgba(255,140,0,0.12); border: 2px solid rgba(255,140,0,0.4); border-radius: 8px; opacity: 0; animation: fadeIn 0.6s ease-out 1.3s forwards; }\n.sumtxt { font-size: 30px; font-weight: 700; color: #ff8c00; text-align: center; }\n.logo { position: absolute; bottom: 60px; right: 50px; font-size: 20px; color: rgba(255,255,255,0.3); }\n</style></head><body>\n<div class=\"c\">\n<div class=\"hd\">{{HEADER}}</div>\n<div class=\"cards\">\n<div class=\"card\"><div class=\"ic\">{{ICON1}}</div><div class=\"lb\">{{LABEL1}}</div><div class=\"vl\">{{VALUE1}}</div><div class=\"desc\">{{DESC1}}</div></div>\n<div class=\"card\"><div class=\"ic\">{{ICON2}}</div><div class=\"lb\">{{LABEL2}}</div><div class=\"vl r\">{{VALUE2}}</div><div class=\"desc\">{{DESC2}}</div></div>\n<div class=\"card\"><div class=\"ic\">{{ICON3}}</div><div class=\"lb\">{{LABEL3}}</div><div class=\"vl\">{{VALUE3}}</div><div class=\"desc\">{{DESC3}}</div></div>\n<div class=\"card\"><div class=\"ic\">{{ICON4}}</div><div class=\"lb\">{{LABEL4}}</div><div class=\"vl o\">{{VALUE4}}</div><div class=\"desc\">{{DESC4}}</div></div>\n</div>\n<div class=\"sum\"><div class=\"sumtxt\">{{SUMMARY}}</div></div>\n<div class=\"logo\">AI科技观察</div>\n</div>\n</body></html>",

  "shot3": "<!DOCTYPE html>\n<html><head><meta charset=\"UTF-8\"><style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { background: #000; display: flex; justify-content: center; font-family: -apple-system, 'PingFang SC', sans-serif; }\n.c { width: 1080px; height: 1920px; background: linear-gradient(180deg, #0f0f1f, #1a1a2e); position: relative; }\n.hd { position: absolute; top: 80px; width: 100%; text-align: center; font-size: 46px; font-weight: 800; color: #fff; opacity: 0; animation: fadeIn 0.5s ease-out 0.2s forwards; }\n.tbl { position: absolute; top: 180px; left: 50px; right: 50px; }\n.th { display: flex; gap: 15px; margin-bottom: 18px; opacity: 0; animation: fadeIn 0.5s ease-out 0.3s forwards; }\n.th div { flex: 1; padding: 16px; background: rgba(255,255,255,0.05); border-radius: 6px; text-align: center; font-size: 24px; font-weight: 700; }\n.th .fr { border: 2px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.6); }\n.th .pl { border: 2px solid rgba(0,212,255,0.3); color: #00d4ff; }\n.th .pr { border: 2px solid rgba(255,51,102,0.4); color: #ff3366; }\n.prrow { display: flex; gap: 15px; margin-bottom: 30px; opacity: 0; animation: scaleIn 0.6s ease-out 0.5s forwards; }\n.prrow div { flex: 1; padding: 32px 18px; border-radius: 6px; text-align: center; }\n.prf { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); }\n.prp { background: rgba(0,212,255,0.05); border: 1px solid rgba(0,212,255,0.2); }\n.prr { background: rgba(255,51,102,0.08); border: 2px solid rgba(255,51,102,0.4); }\n.prlb { font-size: 18px; color: rgba(255,255,255,0.5); margin-bottom: 6px; }\n.prvl { font-size: 40px; font-weight: 900; }\n.prf .prvl { color: rgba(255,255,255,0.7); }\n.prp .prvl { color: #00d4ff; }\n.prr .prvl { color: #ff3366; }\n@keyframes fadeIn { 0% { opacity: 0; } 100% { opacity: 1; } }\n@keyframes scaleIn { 0% { opacity: 0; transform: scale(0.95); } 100% { opacity: 1; transform: scale(1); } }\n.sum { position: absolute; bottom: 140px; left: 50px; right: 50px; padding: 22px; background: rgba(255,140,0,0.12); border: 2px solid rgba(255,140,0,0.4); border-radius: 8px; opacity: 0; animation: fadeIn 0.6s ease-out 1.2s forwards; }\n.sumtxt { font-size: 28px; font-weight: 700; color: #ff8c00; text-align: center; }\n.logo { position: absolute; bottom: 60px; right: 50px; font-size: 20px; color: rgba(255,255,255,0.3); }\n</style></head><body>\n<div class=\"c\">\n<div class=\"hd\">{{HEADER}}</div>\n<div class=\"tbl\">\n<div class=\"th\"><div class=\"fr\">{{COL1}}</div><div class=\"pl\">{{COL2}}</div><div class=\"pr\">{{COL3}}</div></div>\n<div class=\"prrow\">\n<div class=\"prf\"><div class=\"prlb\">价格</div><div class=\"prvl\">{{PRICE1}}</div></div>\n<div class=\"prp\"><div class=\"prlb\">价格</div><div class=\"prvl\">{{PRICE2}}</div></div>\n<div class=\"prr\"><div class=\"prlb\">价格</div><div class=\"prvl\">{{PRICE3}}</div></div>\n</div>\n</div>\n<div class=\"sum\"><div class=\"sumtxt\">{{SUMMARY}}</div></div>\n<div class=\"logo\">AI科技观察</div>\n</div>\n</body></html>",

  "shot4": "<!DOCTYPE html>\n<html><head><meta charset=\"UTF-8\"><style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { background: #000; display: flex; justify-content: center; font-family: -apple-system, 'PingFang SC', sans-serif; }\n.c { width: 1080px; height: 1920px; background: linear-gradient(180deg, #1a1a2e, #0f0f1f); position: relative; }\n.content { position: absolute; top: 300px; left: 50px; right: 50px; text-align: center; }\n.ttl { font-size: 52px; font-weight: 800; color: #fff; margin-bottom: 35px; line-height: 1.4; opacity: 0; animation: scaleIn 0.6s ease-out 0.2s forwards; }\n.hl { color: #00d4ff; text-shadow: 0 0 20px rgba(0,212,255,0.4); }\n.pts { display: flex; flex-direction: column; gap: 18px; margin-top: 40px; }\n.pt { display: flex; align-items: center; gap: 14px; padding: 18px 26px; background: rgba(26,26,46,0.7); border-radius: 8px; font-size: 24px; font-weight: 600; color: #fff; opacity: 0; }\n.pt:nth-child(1) { animation: slideIn 0.5s ease-out 0.6s forwards; }\n.pt:nth-child(2) { animation: slideIn 0.5s ease-out 0.9s forwards; }\n.ic { width: 44px; height: 44px; background: linear-gradient(135deg, #00d4ff, #0099cc); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 20px; }\n.inter { position: absolute; top: 1000px; left: 50px; right: 50px; padding: 36px; background: rgba(255,140,0,0.12); border: 3px solid rgba(255,140,0,0.5); border-radius: 10px; text-align: center; opacity: 0; animation: fadeIn 0.6s ease-out 1.2s forwards; }\n.q { font-size: 34px; font-weight: 700; color: #ff8c00; margin-bottom: 22px; }\n.cta { display: flex; justify-content: center; gap: 18px; }\n.btn { padding: 14px 28px; border-radius: 6px; font-size: 22px; font-weight: 700; color: #fff; }\n.b1 { background: linear-gradient(135deg, #00d4ff, #0099cc); }\n.b2 { background: linear-gradient(135deg, #ff3366, #cc2952); }\n@keyframes fadeIn { 0% { opacity: 0; } 100% { opacity: 1; } }\n@keyframes scaleIn { 0% { opacity: 0; transform: scale(0.85); } 100% { opacity: 1; transform: scale(1); } }\n@keyframes slideIn { 0% { opacity: 0; transform: translateX(-20px); } 100% { opacity: 1; transform: translateX(0); } }\n.bar { position: absolute; bottom: 80px; left: 20%; width: 60%; height: 2px; background: linear-gradient(90deg, transparent, #00d4ff, #ff8c00, transparent); }\n</style></head><body>\n<div class=\"c\">\n<div class=\"content\">\n<div class=\"ttl\">{{TITLE}}<br><span class=\"hl\">{{HIGHLIGHT}}</span></div>\n<div class=\"pts\">\n<div class=\"pt\"><div class=\"ic\">✓</div>{{POINT1}}</div>\n<div class=\"pt\"><div class=\"ic\">✓</div>{{POINT2}}</div>\n</div>\n</div>\n<div class=\"inter\">\n<div class=\"q\">{{QUESTION}}</div>\n<div class=\"cta\"><div class=\"btn b1\">评论区聊聊</div><div class=\"btn b2\">关注看更多</div></div>\n</div>\n<div class=\"bar\"></div>\n</div>\n</body></html>"
