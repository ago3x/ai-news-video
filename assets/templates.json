{
  "_note": "以下为 Reveal.js 竖屏模板参考，与 SKILL.md 规范保持一致（苹果黑风格，#0071e3 蓝）。Agent 应直接根据口播文案编写 HTML，模板仅作结构参考。",

  "cover": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reset.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/theme/black.min.css\">\n<script src=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.js\"></script>\n<style>\n.reveal, .reveal h1, .reveal h2, .reveal h3 {\n  font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', sans-serif;\n  text-transform: none; letter-spacing: -0.02em;\n}\n.reveal h1 { font-size: 3.6em; font-weight: 800; line-height: 1.15; }\n.reveal h2 { font-size: 2.6em; font-weight: 700; }\n.reveal p  { font-size: 1.2em; font-weight: 300; color: #a1a1a6; }\n.hl { color: #0071e3; }\n.badge {\n  display: inline-block; padding: 0.3em 0.9em;\n  background: rgba(0,113,227,0.15);\n  border: 1px solid rgba(0,113,227,0.4);\n  border-radius: 999px; font-size: 0.9em;\n  color: #0071e3; font-weight: 600; margin-bottom: 0.6em;\n}\n</style>\n</head>\n<body>\n<div class=\"reveal\"><div class=\"slides\">\n<section>\n  <div class=\"badge\">{{CATEGORY}}</div>\n  <h1>{{TITLE}}<br><span class=\"hl\">{{HIGHLIGHT}}</span></h1>\n  <p>{{SUBTITLE}}</p>\n</section>\n</div></div>\n<script>\nReveal.initialize({ controls:false, progress:false, transition:'fade', transitionSpeed:'fast',\n  backgroundTransition:'none', width:1080, height:1920, margin:0.06, center:true });\nReveal.on('ready', () => {\n  const dur = parseFloat(new URLSearchParams(location.search).get('dur') || '8');\n  const frags = document.querySelectorAll('.fragment');\n  if (!frags.length) return;\n  const step = (dur - 2) * 0.9 / frags.length;\n  frags.forEach((_, i) => setTimeout(() => Reveal.nextFragment(), (1 + step * i) * 1000));\n});\n</script>\n</body></html>",

  "features": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reset.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/theme/black.min.css\">\n<script src=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.js\"></script>\n<script src=\"https://unpkg.com/lucide@latest/dist/umd/lucide.min.js\"></script>\n<style>\n.reveal, .reveal h1, .reveal h2, .reveal h3 {\n  font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', sans-serif;\n  text-transform: none; letter-spacing: -0.02em;\n}\n.reveal h2 { font-size: 2.2em; font-weight: 700; margin-bottom: 0.6em; }\n.reveal ul { list-style: none; padding: 0; font-size: 1.1em; line-height: 2.2; color: #d2d2d7; }\n.reveal li { margin-bottom: 8px; display: flex; align-items: center; gap: 0.5em; }\n.reveal li strong { color: #f5f5f7; }\n.hl { color: #0071e3; font-weight: 600; }\n.icon-wrap { color: #0071e3; display:inline-flex; }\n</style>\n</head>\n<body>\n<div class=\"reveal\"><div class=\"slides\">\n<section>\n  <h2>{{HEADER}}</h2>\n  <ul>\n    <li class=\"fragment\"><span class=\"icon-wrap\"><i data-lucide=\"{{ICON1}}\" style=\"width:28px;height:28px\"></i></span> {{POINT1}}</li>\n    <li class=\"fragment\"><span class=\"icon-wrap\"><i data-lucide=\"{{ICON2}}\" style=\"width:28px;height:28px\"></i></span> {{POINT2}}</li>\n    <li class=\"fragment\"><span class=\"icon-wrap\"><i data-lucide=\"{{ICON3}}\" style=\"width:28px;height:28px\"></i></span> {{POINT3}}</li>\n    <li class=\"fragment\"><span class=\"icon-wrap\"><i data-lucide=\"{{ICON4}}\" style=\"width:28px;height:28px\"></i></span> {{POINT4}}</li>\n  </ul>\n</section>\n</div></div>\n<script>\nlucide.createIcons();\nReveal.initialize({ controls:false, progress:false, transition:'fade', transitionSpeed:'fast',\n  backgroundTransition:'none', width:1080, height:1920, margin:0.06, center:true });\nReveal.on('ready', () => {\n  const dur = parseFloat(new URLSearchParams(location.search).get('dur') || '8');\n  const frags = document.querySelectorAll('.fragment');\n  if (!frags.length) return;\n  const step = (dur - 2) * 0.9 / frags.length;\n  frags.forEach((_, i) => setTimeout(() => Reveal.nextFragment(), (1 + step * i) * 1000));\n});\n</script>\n</body></html>",

  "compare": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reset.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/theme/black.min.css\">\n<script src=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.js\"></script>\n<style>\n.reveal, .reveal h1, .reveal h2 {\n  font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', sans-serif;\n  text-transform: none; letter-spacing: -0.02em;\n}\n.reveal h2 { font-size: 2em; font-weight: 700; margin-bottom: 0.8em; }\n.cols { display: flex; gap: 1.2em; justify-content: center; }\n.col {\n  flex: 1; padding: 1.4em 1em;\n  border-radius: 24px; text-align: center;\n  border: 1px solid rgba(255,255,255,0.08);\n}\n.col.hi { border-color: rgba(0,113,227,0.5); background: rgba(0,113,227,0.08); }\n.col-label { font-size: 0.85em; color: #a1a1a6; margin-bottom: 0.4em; }\n.col-value { font-size: 2.2em; font-weight: 800; color: #f5f5f7; }\n.col.hi .col-value { color: #0071e3; }\n.col-desc { font-size: 0.75em; color: #a1a1a6; margin-top: 0.4em; }\n</style>\n</head>\n<body>\n<div class=\"reveal\"><div class=\"slides\">\n<section>\n  <h2>{{HEADER}}</h2>\n  <div class=\"cols\">\n    <div class=\"col fragment\">\n      <div class=\"col-label\">{{LABEL1}}</div>\n      <div class=\"col-value\">{{VALUE1}}</div>\n      <div class=\"col-desc\">{{DESC1}}</div>\n    </div>\n    <div class=\"col hi fragment\">\n      <div class=\"col-label\">{{LABEL2}}</div>\n      <div class=\"col-value\">{{VALUE2}}</div>\n      <div class=\"col-desc\">{{DESC2}}</div>\n    </div>\n    <div class=\"col fragment\">\n      <div class=\"col-label\">{{LABEL3}}</div>\n      <div class=\"col-value\">{{VALUE3}}</div>\n      <div class=\"col-desc\">{{DESC3}}</div>\n    </div>\n  </div>\n</section>\n</div></div>\n<script>\nReveal.initialize({ controls:false, progress:false, transition:'fade', transitionSpeed:'fast',\n  backgroundTransition:'none', width:1080, height:1920, margin:0.06, center:true });\nReveal.on('ready', () => {\n  const dur = parseFloat(new URLSearchParams(location.search).get('dur') || '8');\n  const frags = document.querySelectorAll('.fragment');\n  if (!frags.length) return;\n  const step = (dur - 2) * 0.9 / frags.length;\n  frags.forEach((_, i) => setTimeout(() => Reveal.nextFragment(), (1 + step * i) * 1000));\n});\n</script>\n</body></html>",

  "stats": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reset.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/theme/black.min.css\">\n<script src=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.js\"></script>\n<style>\n.reveal, .reveal h1, .reveal h2 {\n  font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', sans-serif;\n  text-transform: none; letter-spacing: -0.02em;\n}\n.reveal h2 { font-size: 2em; font-weight: 700; }\n.big-num { font-size: 5.5em; font-weight: 900; color: #0071e3; line-height: 1; }\n.unit { font-size: 0.4em; color: #a1a1a6; font-weight: 400; }\n.desc { font-size: 1.1em; color: #a1a1a6; margin-top: 0.5em; }\n</style>\n</head>\n<body>\n<div class=\"reveal\"><div class=\"slides\">\n<section>\n  <h2>{{HEADER}}</h2>\n  <div class=\"big-num fragment\">\n    <span data-count=\"{{NUMBER}}\">0</span><span class=\"unit\">{{UNIT}}</span>\n  </div>\n  <div class=\"desc fragment\">{{DESCRIPTION}}</div>\n</section>\n</div></div>\n<script>\nfunction countUp(el, target, ms) {\n  ms = ms || 1200;\n  const t0 = performance.now();\n  const go = now => {\n    const p = Math.min((now - t0) / ms, 1);\n    el.textContent = Math.floor((1 - Math.pow(1-p,3)) * target).toLocaleString();\n    if (p < 1) requestAnimationFrame(go);\n  };\n  requestAnimationFrame(go);\n}\nReveal.initialize({ controls:false, progress:false, transition:'fade', transitionSpeed:'fast',\n  backgroundTransition:'none', width:1080, height:1920, margin:0.06, center:true });\nReveal.on('ready', () => {\n  const dur = parseFloat(new URLSearchParams(location.search).get('dur') || '8');\n  const frags = document.querySelectorAll('.fragment');\n  if (!frags.length) return;\n  const step = (dur - 2) * 0.9 / frags.length;\n  frags.forEach((_, i) => setTimeout(() => Reveal.nextFragment(), (1 + step * i) * 1000));\n});\nReveal.on('fragmentshown', e => {\n  e.fragment.querySelectorAll('[data-count]').forEach(el => countUp(el, +el.dataset.count));\n});\n</script>\n</body></html>",

  "ending": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reset.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/theme/black.min.css\">\n<script src=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.js\"></script>\n<script src=\"https://unpkg.com/lucide@latest/dist/umd/lucide.min.js\"></script>\n<style>\n.reveal, .reveal h1, .reveal h2 {\n  font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', sans-serif;\n  text-transform: none; letter-spacing: -0.02em;\n}\n.reveal h2 { font-size: 2.2em; font-weight: 700; }\n.reveal ul { list-style: none; padding: 0; font-size: 1em; line-height: 2; color: #d2d2d7; }\n.reveal li::before { content: '✓ '; color: #0071e3; font-weight: 700; }\n.question {\n  margin-top: 1.2em; padding: 1em 1.2em;\n  background: rgba(0,113,227,0.1);\n  border: 1px solid rgba(0,113,227,0.3);\n  border-radius: 16px; font-size: 1.1em;\n  color: #f5f5f7; line-height: 1.6;\n}\n</style>\n</head>\n<body>\n<div class=\"reveal\"><div class=\"slides\">\n<section>\n  <h2>{{TITLE}}</h2>\n  <ul>\n    <li class=\"fragment\">{{POINT1}}</li>\n    <li class=\"fragment\">{{POINT2}}</li>\n    <li class=\"fragment\">{{POINT3}}</li>\n  </ul>\n  <div class=\"question fragment\">{{QUESTION}}</div>\n</section>\n</div></div>\n<script>\nlucide.createIcons();\nReveal.initialize({ controls:false, progress:false, transition:'fade', transitionSpeed:'fast',\n  backgroundTransition:'none', width:1080, height:1920, margin:0.06, center:true });\nReveal.on('ready', () => {\n  const dur = parseFloat(new URLSearchParams(location.search).get('dur') || '8');\n  const frags = document.querySelectorAll('.fragment');\n  if (!frags.length) return;\n  const step = (dur - 2) * 0.9 / frags.length;\n  frags.forEach((_, i) => setTimeout(() => Reveal.nextFragment(), (1 + step * i) * 1000));\n});\n</script>\n</body></html>"
