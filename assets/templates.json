  "image-caption": "<!DOCTYPE html>\n<html data-theme=\"{{THEME}}\">\n<head>\n<meta charset=\"UTF-8\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reset.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.css\">\n<script src=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.js\"></script>\n<style>\n[data-theme=\"apple\"]{--bg:#000;--accent:#0071e3;--muted:#a1a1a6;--text:#f5f5f7;--card-bg:rgba(255,255,255,0.05);--card-border:rgba(255,255,255,0.08)}\n[data-theme=\"cyber\"]{--bg:#050510;--accent:#00ff88;--muted:#7aff7a;--text:#e0ffe0;--card-bg:rgba(0,255,136,0.05);--card-border:rgba(0,255,136,0.2)}\n[data-theme=\"media\"]{--bg:#1a1a1a;--accent:#f59e0b;--muted:#d1d1d1;--text:#f5f5f5;--card-bg:rgba(245,158,11,0.08);--card-border:rgba(245,158,11,0.3)}\n[data-theme=\"light\"]{--bg:#f8f8f8;--accent:#e84393;--muted:#555;--text:#111;--card-bg:rgba(232,67,147,0.06);--card-border:rgba(232,67,147,0.2)}\n.reveal { background: var(--bg) !important; }\n.reveal, .reveal h1, .reveal h2, .reveal h3 {\n  font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', sans-serif;\n  text-transform: none; letter-spacing: -0.02em; color: var(--text);\n}\n.img-wrap {\n  height: 60vh; border-radius: 20px;\n  background: var(--card-bg);\n  border: 1px solid var(--card-border);\n  overflow: hidden; margin-bottom: 1em;\n}\n.img-wrap img { width: 100%; height: 100%; object-fit: cover; }\n.img-title { font-size: 1.8em; font-weight: 800; color: var(--text); margin-bottom: 0.4em; line-height: 1.3; }\n.img-sub { font-size: 1em; color: var(--muted); line-height: 1.6; }\n.img-sub .accent { color: var(--accent); }\n</style>\n</head>\n<body>\n<div class=\"reveal\"><div class=\"slides\">\n<section style=\"text-align:left\">\n  <div class=\"img-wrap fragment\">\n    <img src=\"{{IMG_PATH}}\" alt=\"{{IMG_ALT}}\">\n  </div>\n  <div class=\"img-title fragment\">{{TITLE}}</div>\n  <div class=\"img-sub fragment\"><span class=\"accent\">{{ACCENT_WORD}}</span> {{SUBTITLE}}</div>\n</section>\n</div></div>\n<script>\nReveal.initialize({ controls:false, progress:false, transition:'fade', transitionSpeed:'fast',\n  backgroundTransition:'none', width:1080, height:1920, margin:0.06, center:false });\nReveal.on('ready',()=>{const dur=parseFloat(new URLSearchParams(location.search).get('dur')||'8');const frags=document.querySelectorAll('.fragment');if(!frags.length)return;const step=(dur-2)*0.9/frags.length;frags.forEach((_,i)=>setTimeout(()=>Reveal.nextFragment(),(1+step*i)*1000));});\n</script>\n</body></html>",

  "split-image": "<!DOCTYPE html>\n<html data-theme=\"{{THEME}}\">\n<head>\n<meta charset=\"UTF-8\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reset.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.css\">\n<script src=\"https://cdn.jsdelivr.net/npm/reveal.js@5.0.4/dist/reveal.min.js\"></script>\n<style>\n[data-theme=\"apple\"]{--bg:#000;--accent:#0071e3;--muted:#a1a1a6;--text:#f5f5f7;--card-bg:rgba(255,255,255,0.05);--card-border:rgba(255,255,255,0.08)}\n[data-theme=\"cyber\"]{--bg:#050510;--accent:#00ff88;--muted:#7aff7a;--text:#e0ffe0;--card-bg:rgba(0,255,136,0.05);--card-border:rgba(0,255,136,0.2)}\n[data-theme=\"media\"]{--bg:#1a1a1a;--accent:#f59e0b;--muted:#d1d1d1;--text:#f5f5f5;--card-bg:rgba(245,158,11,0.08);--card-border:rgba(245,158,11,0.3)}\n[data-theme=\"light\"]{--bg:#f8f8f8;--accent:#e84393;--muted:#555;--text:#111;--card-bg:rgba(232,67,147,0.06);--card-border:rgba(232,67,147,0.2)}\n.reveal { background: var(--bg) !important; }\n.reveal, .reveal h1, .reveal h2, .reveal h3 {\n  font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', sans-serif;\n  text-transform: none; letter-spacing: -0.02em; color: var(--text);\n}\n.top-img {\n  height: 50vh; border-radius: 20px 20px 0 0; overflow: hidden;\n  margin-bottom: 0;\n}\n.top-img img { width: 100%; height: 100%; object-fit: cover; }\n.text-area { padding: 1.2em 0.4em 0; }\n.badge {\n  display: inline-block; padding: 0.25em 0.8em;\n  background: var(--card-bg);\n  border: 1px solid var(--card-border);\n  border-radius: 999px; font-size: 0.8em;\n  color: var(--accent); font-weight: 600; margin-bottom: 0.6em;\n}\n.si-title { font-size: 1.9em; font-weight: 800; color: var(--text); line-height: 1.3; margin-bottom: 0.5em; }\n.si-body { font-size: 0.95em; color: var(--muted); line-height: 1.7; }\n</style>\n</head>\n<body>\n<div class=\"reveal\"><div class=\"slides\">\n<section style=\"text-align:left\">\n  <div class=\"top-img fragment\">\n    <img src=\"{{IMG_PATH}}\" alt=\"{{IMG_ALT}}\">\n  </div>\n  <div class=\"text-area\">\n    <div class=\"badge fragment\">{{BADGE}}</div>\n    <div class=\"si-title fragment\">{{TITLE}}</div>\n    <div class=\"si-body fragment\">{{BODY}}</div>\n  </div>\n</section>\n</div></div>\n<script>\nReveal.initialize({ controls:false, progress:false, transition:'fade', transitionSpeed:'fast',\n  backgroundTransition:'none', width:1080, height:1920, margin:0.06, center:false });\nReveal.on('ready',()=>{const dur=parseFloat(new URLSearchParams(location.search).get('dur')||'8');const frags=document.querySelectorAll('.fragment');if(!frags.length)return;const step=(dur-2)*0.9/frags.length;frags.forEach((_,i)=>setTimeout(()=>Reveal.nextFragment(),(1+step*i)*1000));});\n</script>\n</body></html>"
}
